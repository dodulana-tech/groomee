generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  PRO
}

enum ProStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REMOVED

  @@map("GroomerStatus")
}

enum ProAvail {
  ONLINE
  BUSY
  OFFLINE

  @@map("GroomerAvail")
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
}

enum BookingStatus {
  PENDING_PAYMENT
  DISPATCHING
  NO_GROOMER
  ACCEPTED
  EN_ROUTE
  ARRIVED
  IN_SERVICE
  COMPLETED
  CONFIRMED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  AUTHORISED
  CAPTURED
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum ServiceCategory {
  HAIR
  MAKEUP
  NAILS
  BARBING
  LASHES
  SKINCARE
  OTHER
}

model User {
  id                String         @id @default(cuid())
  phone             String         @unique
  name              String?
  email             String?
  role              UserRole       @default(CUSTOMER)
  points            Int            @default(0)
  adminRoleId       String?
  adminRole         AdminRole?     @relation(fields: [adminRoleId], references: [id])
  bookings          Booking[]
  favouritePros     FavouritePro[]
  beautyProfile     BeautyProfile?
  subscriptions     Subscription[]
  giftCardsSent     GiftCard[]     @relation("GiftSender")
  giftCardsUsed     GiftCard[]     @relation("GiftRedeemer")
  referralsMade     Referral[]     @relation("Referrer")
  referralsReceived Referral[]     @relation("Referred")
  notes             Note[]
  activityLogs      ActivityLog[]
  pointsLedger      PointsLedger[]
  pro               Pro?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("users")
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  permissions String[] @default([])
  isSystem    Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admin_roles")
}

model Note {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("notes")
}

model ActivityLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([adminId])
  @@map("activity_logs")
}

model Pro {
  id               String           @id @default(cuid())
  userId           String?          @unique
  user             User?            @relation(fields: [userId], references: [id])
  name             String
  phone            String           @unique
  status           ProStatus        @default(PENDING)
  availability     ProAvail         @default(OFFLINE)
  currentBookingId String?
  commission       Float            @default(0.20)
  avgRating        Float            @default(0)
  reviewCount      Int              @default(0)
  totalJobs        Int              @default(0)
  acceptanceRate   Float            @default(0)
  strikeCount      Int              @default(0) @map("strikes")
  bankCode         String?
  bankAccount      String?
  bankName         String?
  bankAccountNo    String?
  idVerified       Boolean          @default(false)
  gender           Gender?
  photo            String?
  bio              String?
  services         ProService[]
  zones            ProZone[]
  bookings         Booking[]
  earnings         Earning[]
  favouritedBy     FavouritePro[]
  advances         ProAdvance[]
  creditEvents     ProCreditEvent[]
  strikes          Strike[]
  payouts          Payout[]
  schedule         ProSchedule[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("groomers")
}

model FavouritePro {
  id        String   @id @default(cuid())
  userId    String
  proId     String   @map("groomerId")
  priority  Int      @default(0)
  user      User     @relation(fields: [userId], references: [id])
  pro       Pro      @relation(fields: [proId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, proId])
  @@map("favourite_pros")
}

model Service {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  category     ServiceCategory
  basePrice    Float
  minPrice     Float
  maxPrice     Float
  durationMins Int
  description  String?
  isActive     Boolean         @default(true)
  sortOrder    Int             @default(0)
  pros         ProService[]
  bookings     Booking[]
  createdAt    DateTime        @default(now())

  @@map("services")
}

model Zone {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  city     String    @default("Lagos")
  pros     ProZone[]
  bookings Booking[]

  @@map("zones")
}

model ProService {
  proId       String  @map("groomerId")
  serviceId   String
  customPrice Float?
  pro         Pro     @relation(fields: [proId], references: [id])
  service     Service @relation(fields: [serviceId], references: [id])

  @@id([proId, serviceId])
  @@map("groomer_services")
}

model ProZone {
  proId  String @map("groomerId")
  zoneId String
  pro    Pro    @relation(fields: [proId], references: [id])
  zone   Zone   @relation(fields: [zoneId], references: [id])

  @@id([proId, zoneId])
  @@map("groomer_zones")
}

model Booking {
  id               String        @id @default(cuid())
  reference        String        @unique
  customerId       String
  proId            String?       @map("groomerId")
  serviceId        String
  zoneId           String?
  status           BookingStatus @default(PENDING_PAYMENT)
  address          String
  latitude         Float?
  longitude        Float?
  isAsap           Boolean       @default(false)
  scheduledFor     DateTime?
  customerNotes    String?
  totalAmount      Float
  baseAmount       Float
  surchargeAmount  Float         @default(0)
  surchargeType    String?
  proEarning       Float         @default(0) @map("groomerEarning")
  dispatchAttempts Int           @default(0)
  acceptedAt       DateTime?
  enRouteAt        DateTime?
  arrivedAt        DateTime?
  completedAt      DateTime?
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  customer         User          @relation(fields: [customerId], references: [id])
  pro              Pro?          @relation(fields: [proId], references: [id])
  service          Service       @relation(fields: [serviceId], references: [id])
  zone             Zone?         @relation(fields: [zoneId], references: [id])
  payment          Payment?
  dispute          Dispute?
  review           Review?
  dispatchLog      DispatchLog[]
  strikes          Strike[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([customerId, createdAt])
  @@index([proId])
  @@index([status, createdAt])
  @@map("bookings")
}

model DispatchLog {
  id        String    @id @default(cuid())
  bookingId String
  proId     String    @map("groomerId")
  proName   String    @map("groomerName")
  offeredAt DateTime  @default(now())
  response  String?
  respondAt DateTime?
  booking   Booking   @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([proId])
  @@map("dispatch_logs")
}

model Payment {
  id           String        @id @default(cuid())
  bookingId    String        @unique
  reference    String        @unique
  amount       Float
  status       PaymentStatus @default(PENDING)
  paystackRef  String?
  authorisedAt DateTime?
  capturedAt   DateTime?
  refundedAt   DateTime?
  refundAmount Float?
  booking      Booking       @relation(fields: [bookingId], references: [id])
  createdAt    DateTime      @default(now())

  @@index([status, capturedAt])
  @@map("payments")
}

model Dispute {
  id           String        @id @default(cuid())
  bookingId    String        @unique
  status       DisputeStatus @default(OPEN)
  reason       String
  notes        String?
  resolution   String?
  refundAmount Float?
  booking      Booking       @relation(fields: [bookingId], references: [id])
  createdAt    DateTime      @default(now())
  resolvedAt   DateTime?

  @@map("disputes")
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  rating    Int
  text      String?
  booking   Booking  @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())

  @@map("reviews")
}

model Earning {
  proId     String   @map("groomerId")
  id        String   @id @default(cuid())
  bookingId String   @unique
  amount    Float
  paid      Boolean  @default(false)
  payoutId  String?
  pro       Pro      @relation(fields: [proId], references: [id])
  createdAt DateTime @default(now())

  @@index([proId, paid])
  @@map("earnings")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

model Notification {
  id        String    @id @default(cuid())
  recipient String
  channel   String
  message   String
  status    String
  sentAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

model OtpCode {
  id        String    @id @default(cuid())
  phone     String
  code      String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([phone])
}

model SurveyResponse {
  id        String   @id @default(cuid())
  type      String
  phone     String?
  email     String?
  answers   Json
  createdAt DateTime @default(now())

  @@map("survey_responses")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  name      String?
  city      String   @default("Abuja")
  area      String?
  role      String   @default("customer")
  createdAt DateTime @default(now())

  @@map("waitlist")
}

model BeautyProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  hairType          String?
  hairLength        String?
  hairTexture       String?
  scalpCondition    String?
  colourTreated     Boolean  @default(false)
  skinTone          String?
  skinType          String?
  allergies         String[] @default([])
  preferredProducts String[] @default([])
  avoidProducts     String[] @default([])
  favouriteStyles   String[] @default([])
  styleNotes        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("beauty_profiles")
}

model SubscriptionPlan {
  id               String         @id @default(cuid())
  name             String
  price            Float
  credits          Int
  discountRate     Float          @default(0)
  priorityDispatch Boolean        @default(false)
  description      String?
  isActive         Boolean        @default(true)
  sortOrder        Int            @default(0)
  subscriptions    Subscription[]
  createdAt        DateTime       @default(now())

  @@map("subscription_plans")
}

model Subscription {
  id                 String              @id @default(cuid())
  userId             String
  planId             String
  status             String              @default("PENDING")
  currentPeriodStart DateTime            @default(now())
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime
  creditsRemaining   Int
  creditsTotal       Int
  cancelledAt        DateTime?
  cancelReason       String?
  paystackAuthCode   String?
  user               User                @relation(fields: [userId], references: [id])
  plan               SubscriptionPlan    @relation(fields: [planId], references: [id])
  usages             SubscriptionUsage[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId, status])
  @@map("subscriptions")
}

model SubscriptionUsage {
  id             String       @id @default(cuid())
  subscriptionId String
  bookingId      String?
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  createdAt      DateTime     @default(now())

  @@map("subscription_usages")
}

model GiftCard {
  id             String    @id @default(cuid())
  code           String    @unique
  senderId       String
  recipientPhone String
  recipientName  String?
  message        String?
  serviceId      String?
  amount         Float
  expiresAt      DateTime
  isRedeemed     Boolean   @default(false)
  redeemedAt     DateTime?
  redeemedBy     String?
  bookingId      String?
  sender         User      @relation("GiftSender", fields: [senderId], references: [id])
  redeemer       User?     @relation("GiftRedeemer", fields: [redeemedBy], references: [id])
  createdAt      DateTime  @default(now())

  @@map("gift_cards")
}

model ProAdvance {
  id        String   @id @default(cuid())
  proId     String   @map("groomerId")
  amount    Float
  reason    String
  status    String   @default("PENDING")
  pro       Pro      @relation(fields: [proId], references: [id])
  createdAt DateTime @default(now())

  @@map("pro_advances")
}

model ProCreditEvent {
  id          String   @id @default(cuid())
  proId       String   @map("groomerId")
  eventType   String
  points      Int
  description String
  pro         Pro      @relation(fields: [proId], references: [id])
  createdAt   DateTime @default(now())

  @@map("pro_credit_events")
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredPhone  String   @default("")
  referredUserId String?
  bonusAmount    Float    @default(2000)
  bonusPaid      Boolean  @default(false)
  referrer       User     @relation("Referrer", fields: [referrerId], references: [id])
  referred       User?    @relation("Referred", fields: [referredUserId], references: [id])
  createdAt      DateTime @default(now())

  @@map("referrals")
}

model Strike {
  id        String   @id @default(cuid())
  proId     String   @map("groomerId")
  bookingId String
  reason    String
  notes     String?
  pro       Pro      @relation(fields: [proId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())

  @@map("strikes")
}

model PointsLedger {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  reason      String
  referenceId String?
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@map("points_ledger")
}

model Payout {
  id                 String    @id @default(cuid())
  proId              String    @map("groomerId")
  amount             Float
  status             String    @default("PROCESSING")
  paystackTransferId String?
  recipientCode      String?
  periodStart        DateTime
  periodEnd          DateTime
  processedAt        DateTime?
  failureReason      String?
  pro                Pro       @relation(fields: [proId], references: [id])
  createdAt          DateTime  @default(now())

  @@map("payouts")
}

model ProSchedule {
  id        String  @id @default(cuid())
  proId     String  @map("groomerId")
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
  pro       Pro     @relation(fields: [proId], references: [id])

  @@unique([proId, dayOfWeek])
  @@map("pro_schedules")
}
